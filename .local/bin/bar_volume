#!/bin/bash

# VOLUME
volume=$(pamixer --get-volume)
is_muted=$(pamixer --get-volume-human)
if [ "$is_muted" == "muted" ]; then
	volume_icon="ó°ťź"
else
if (( $volume > 59 )); then
    volume_icon="ó°•ľ"
elif (( $volume > 19 )); then
    volume_icon="ó°–€"
else (( $volume > 0 ));
    volume_icon="ó°•ż"
fi
fi
echo "$volume_icon $is_muted"
